rules_version = '2';

// Security rules for MentorMinds.
// Phase 4: points, badges, streak, rewards ledger are server-authoritative only.

service cloud.firestore {
  match /databases/{database}/documents {

    // -------------------------------------------------------------------------
    // Helpers
    // -------------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && userDoc().role == 'admin';
    }

    function isApprovedTeacher() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && userDoc().role == 'teacher'
        && userDoc().get('isApproved', false) == true;
    }

    // Phase 4 REWD-05: client cannot mutate gamification fields on self-update.
    function ownerPreservesGamificationFields() {
      return !request.resource.data.diff(resource.data).affectedKeys()
        .hasAny(['points', 'badges', 'streakDays', 'sessionsCompleted',
                 'totalQuestions', 'diagramUploads', 'questionsPerSubject']);
    }

    function sessionOwnerUidFrom(data) {
      return data.get('userId', data.get('uid', ''));
    }

    function sessionOwnerUid() {
      return sessionOwnerUidFrom(resource.data);
    }

    function sessionRequestOwnerUid() {
      return sessionOwnerUidFrom(request.resource.data);
    }

    // -------------------------------------------------------------------------
    // /users/{uid}
    // -------------------------------------------------------------------------

    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();

      allow create: if isOwner(uid)
        && request.resource.data.uid == uid
        && request.resource.data.role in ['student', 'teacher']
        && request.resource.data.get('points', 0) == 0
        && request.resource.data.get('badges', []).size() == 0
        && (
          request.resource.data.role != 'teacher' ||
          request.resource.data.get('isApproved', true) == false
        );

      allow update: if isAdmin() || (
        isOwner(uid)
        && request.resource.data.role == resource.data.role
        && request.resource.data.get('isApproved', false)
           == resource.data.get('isApproved', false)
        && ownerPreservesGamificationFields()
      );

      allow delete: if isAdmin();

      match /usage/{dateKey} {
        allow read: if isOwner(uid);
        allow write: if false;
      }
    }

    // -------------------------------------------------------------------------
    // /rewards/{uid} — read-only for clients (REWD-05)
    // -------------------------------------------------------------------------

    match /rewards/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create, update, delete: if false;

      match /ledger/{ledgerId} {
        allow read: if isOwner(uid) || isAdmin();
        allow write: if false;
      }
    }

    // -------------------------------------------------------------------------
    // /sessions/{sid} — messages written by mentorBotChat (Admin SDK)
    // -------------------------------------------------------------------------

    match /sessions/{sid} {
      allow read: if isSignedIn()
        && sessionOwnerUid() == request.auth.uid;

      allow create: if isSignedIn()
        && sessionRequestOwnerUid() == request.auth.uid;

      allow update: if isSignedIn()
        && sessionOwnerUid() == request.auth.uid
        && sessionRequestOwnerUid() == request.auth.uid;

      allow delete: if isSignedIn()
        && sessionOwnerUid() == request.auth.uid;

      match /messages/{mid} {
        allow read: if isSignedIn()
          && sessionOwnerUidFrom(
               get(/databases/$(database)/documents/sessions/$(sid)).data
             ) == request.auth.uid;
        allow write: if false;
      }
    }

    // -------------------------------------------------------------------------
    // /subscriptions/{uid} — PAY-01 (read-only for owner; writes via Functions)
    // -------------------------------------------------------------------------

    match /subscriptions/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow write: if false;
    }

    // -------------------------------------------------------------------------
    // /materials/{id}
    // -------------------------------------------------------------------------

    match /materials/{id} {
      allow read: if isSignedIn();
      allow create, update: if isApprovedTeacher() || isAdmin();
      allow delete: if isAdmin();
    }

    // -------------------------------------------------------------------------
    // /notifications/{id}
    // -------------------------------------------------------------------------

    match /notifications/{id} {
      allow read: if isSignedIn();
      allow create: if isAdmin();
      allow update: if isSignedIn()
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['read'])
        && request.resource.data.read == true;
      allow delete: if isSignedIn();
    }

    // -------------------------------------------------------------------------
    // /system/** — server-only
    // -------------------------------------------------------------------------

    match /system/{document=**} {
      allow read, write: if false;
    }
  }
}
