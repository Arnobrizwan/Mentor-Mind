rules_version = '2';

// Security rules for MentorMinds.
// Phase 4: points, badges, streak, rewards ledger are server-authoritative only.

service cloud.firestore {
  match /databases/{database}/documents {

    // -------------------------------------------------------------------------
    // Helpers
    // -------------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && userDoc().role == 'admin';
    }

    function isApprovedTeacher() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && userDoc().role == 'teacher'
        && userDoc().get('isApproved', false) == true;
    }

    // Phase 4 REWD-05: client cannot mutate gamification fields on self-update.
    function ownerPreservesGamificationFields() {
      return !request.resource.data.diff(resource.data).affectedKeys()
        .hasAny(['points', 'badges', 'streakDays', 'sessionsCompleted',
                 'totalQuestions', 'diagramUploads', 'questionsPerSubject']);
    }

    function sessionOwnerUidFrom(data) {
      return data.get('userId', data.get('uid', ''));
    }

    function sessionOwnerUid() {
      return sessionOwnerUidFrom(resource.data);
    }

    function sessionRequestOwnerUid() {
      return sessionOwnerUidFrom(request.resource.data);
    }

    // -------------------------------------------------------------------------
    // /users/{uid}
    // -------------------------------------------------------------------------

    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();

      allow create: if isOwner(uid)
        && request.resource.data.uid == uid
        && request.resource.data.role in ['student', 'teacher']
        && request.resource.data.get('points', 0) == 0
        && request.resource.data.get('badges', []).size() == 0
        && (
          request.resource.data.role != 'teacher' ||
          request.resource.data.get('isApproved', true) == false
        );

      allow update: if isAdmin() || (
        isOwner(uid)
        && request.resource.data.role == resource.data.role
        && request.resource.data.get('isApproved', false)
           == resource.data.get('isApproved', false)
        && ownerPreservesGamificationFields()
      );

      allow delete: if isAdmin();

      match /usage/{dateKey} {
        allow read: if isOwner(uid);
        allow write: if false;
      }
    }

    // -------------------------------------------------------------------------
    // /rewards/{uid} — read-only for clients (REWD-05)
    // -------------------------------------------------------------------------

    match /rewards/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create, update, delete: if false;

      match /ledger/{ledgerId} {
        allow read: if isOwner(uid) || isAdmin();
        allow write: if false;
      }
    }

    // -------------------------------------------------------------------------
    // /sessions/{sid} — messages written by mentorBotChat (Admin SDK)
    // -------------------------------------------------------------------------

    match /sessions/{sid} {
      allow read: if isSignedIn()
        && sessionOwnerUid() == request.auth.uid;

      allow create: if isSignedIn()
        && sessionRequestOwnerUid() == request.auth.uid;

      allow update: if isSignedIn()
        && sessionOwnerUid() == request.auth.uid
        && sessionRequestOwnerUid() == request.auth.uid;

      allow delete: if isSignedIn()
        && sessionOwnerUid() == request.auth.uid;

      match /messages/{mid} {
        allow read: if isSignedIn()
          && sessionOwnerUidFrom(
               get(/databases/$(database)/documents/sessions/$(sid)).data
             ) == request.auth.uid;
        allow write: if false;
      }
    }

    // -------------------------------------------------------------------------
    // /subscriptions/{uid} — PAY-01 (read-only for owner; writes via Functions)
    // -------------------------------------------------------------------------

    match /subscriptions/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow write: if false;
    }

    // -------------------------------------------------------------------------
    // /materials/{id}
    // -------------------------------------------------------------------------

    match /materials/{id} {
      allow read: if isSignedIn();
      allow create: if isApprovedTeacher() || isAdmin();
      // Teachers/admins can update any field. Any signed-in user (students
      // included) can increment the `views` counter by +1 — and nothing else.
      // This keeps analytics accurate without granting students free write
      // access to material content.
      allow update: if isApprovedTeacher() || isAdmin()
        || (isSignedIn()
            && request.resource.data.diff(resource.data).affectedKeys()
                 .hasOnly(['views'])
            && request.resource.data.views is int
            && request.resource.data.views == resource.data.views + 1);
      allow delete: if isAdmin();
    }

    // -------------------------------------------------------------------------
    // /notifications/{id}
    // -------------------------------------------------------------------------

    match /daily_challenges/{dateKey} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /notifications/{id} {
      allow read: if isSignedIn();
      // Three creator paths:
      //   1. Admins create anything.
      //   2. Any signed-in user persists their own FCM-ingest notifications
      //      (source == 'fcm_client', unread).
      //   3. Approved teachers may post student-targeted announcements,
      //      stamped with their uid as `createdBy` so we can audit/throttle.
      allow create: if isAdmin() || (
        isSignedIn()
        && request.resource.data.get('source', '') == 'fcm_client'
        && request.resource.data.read == false
      ) || (
        isApprovedTeacher()
        && request.resource.data.get('source', '') == 'teacher_announcement'
        && request.resource.data.get('createdBy', '') == request.auth.uid
        && request.resource.data.recipientRole == 'student'
        && request.resource.data.type == 'announcement'
        && request.resource.data.read == false
      );
      allow update: if isSignedIn()
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['read'])
        && request.resource.data.read == true;
      allow delete: if isSignedIn();
    }

    // -------------------------------------------------------------------------
    // /config/{docId} — admin-editable runtime config (gamification,
    // curriculum, quotas). Clients READ to render badges/subjects/limits;
    // ONLY admins may write. Edits land via Firebase Console.
    // -------------------------------------------------------------------------

    match /config/{docId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    // -------------------------------------------------------------------------
    // /system/** — server-only (admins may read daily usage_log_* aggregates)
    // -------------------------------------------------------------------------

    match /system/{docId} {
      allow read: if isAdmin() && docId.matches('usage_log_[0-9]{4}-[0-9]{2}-[0-9]{2}');
      allow write: if false;
    }

    match /system/{document=**} {
      allow read, write: if false;
    }
  }
}
